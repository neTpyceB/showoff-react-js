{
  "name": "showoff-react-js",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server/index.ts --mode dev --host 127.0.0.1 --port 5173",
    "e2e:serve": "tsx server/index.ts --mode preview --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "tsx server/index.ts --mode preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "test": "npm run test:unit && npm run test:smoke",
    "test:unit": "vitest run --project unit --project server",
    "test:smoke": "vitest run --project smoke",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node ./e2e/test.mjs",
    "test:e2e:external": "node ./e2e/run.mjs",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.6",
    "@tanstack/react-virtual": "^3.13.12",
    "cookie-parser": "^1.4.7",
    "express": "^5.1.0",
    "idb": "^8.0.3",
    "multer": "^2.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.66.0",
    "react-router-dom": "^7.9.6",
    "ws": "^8.18.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.8",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.4",
    "globals": "^17.4.0",
    "jsdom": "^27.1.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.0.8"
  }
}
