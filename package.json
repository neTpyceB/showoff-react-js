{
  "name": "showoff-react-js",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 5173",
    "e2e:serve": "next dev --hostname 127.0.0.1",
    "build": "next build",
    "lint": "eslint .",
    "preview": "next start --hostname 0.0.0.0 --port 4173",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:smoke",
    "test:unit": "vitest run --project unit --project server",
    "test:smoke": "vitest run --project smoke",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node ./e2e/test.mjs",
    "test:e2e:external": "node ./e2e/run.mjs",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.8",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.4",
    "globals": "^17.4.0",
    "jsdom": "^27.1.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.8"
  }
}
